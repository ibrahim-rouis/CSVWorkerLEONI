@using CSVWorker.Models.Entities
@model IMDSPorscheDatabaseRecord

@{
    ViewData["Title"] = "Details";
}

<h1 class="fs-3">Details</h1>


<div class="card">
    <h5 class="card-header">Details for id @Html.DisplayFor(model => model.Id)</h5>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CreatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.createdBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.createdBy)
            </dd>
        </dl>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.LastUpdatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.LastUpdatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.LastUpdatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.LastUpdatedBy)
            </dd>
        </dl>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PartNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PartNumber)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PartNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PartNumber)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ArticleName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ArticleName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.MaterialGroup)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.MaterialGroup)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.CrossSec)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CrossSec)
            </dd>           
        </dl>
        <a asp-action="Index" class="btn btn-secondary mx-2">Back</a>
    </div>
</div>
