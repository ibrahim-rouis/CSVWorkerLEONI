@using CSVWorker.Security

@{
    TempData.Keep();
    string? currentPage = ViewContext.HttpContext.Request.Path;
}

<!-- Menu -->
@* ! Do this simple *@
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">

    @* ! Hide app brand if navbar-full *@
    <div
        class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
        <a asp-controller="Home" asp-action="Index" class="app-brand-link">
            <span class="app-brand-logo demo">
                @await Html.PartialAsync("../_Partials/_Brand")
            </span>
            <span class="app-brand-text demo menu-text fw-bold ms-2">@TempData.Peek("appName")</span>
        </a>

        <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
            <i class="icon-base bx bx-chevron-left d-block d-xl-none align-middle"></i>
        </a>
    </div>

    <div class="menu-divider mt-0"></div>

    <div class="menu-inner-shadow"></div>

    @* ! menu-items *@
    <ul class="menu-inner py-1">

        @if (User.IsInRole(Roles.Admin))
        {
            <!-- Misc -->
            <li class="menu-header small text-uppercase"><span class="menu-header-text">Admin</span></li>

            <li class='menu-item@(currentPage.StartsWith("/LogViewer") ? " active" : "")'>
                <a asp-controller="LogViewer"
                   asp-route-viewMode="month"
                   asp-route-levelFilter="ERR"
                   asp-route-month="@DateTime.Now.Month"
                   asp-route-year="@DateTime.Now.Year"
                   asp-action="Index" class="menu-link">
                    <i class="menu-icon icon-base bx bx-file"></i>
                    <div class="text-truncate">Logs Viewer</div>
                </a>
            </li>
            <!--/ Misc -->
        }

        <!-- Databases -->
        <li class="menu-header small text-uppercase"><span class="menu-header-text">Databases</span></li>

        <li class='menu-item@(currentPage.StartsWith("/IMDSDatabase") ? " active" : "")'>
            <a asp-controller="IMDSDatabase" asp-action="Index" class="menu-link">
                <i class="menu-icon icon-base bx bx-data"></i>
                <div class="text-truncate">IMDS Database</div>
            </a>
        </li>

        <li class='menu-item@(currentPage.StartsWith("/IMDSPorscheDatabase") ? " active" : "")'>
            <a asp-controller="IMDSPorscheDatabase" asp-action="Index" class="menu-link">
                <i class="menu-icon icon-base bx bx-data"></i>
                <div class="text-truncate">Porsche Database</div>
            </a>
        </li>
        <!--/ Databases -->

        <!-- Macros -->
        <li class="menu-header small text-uppercase">
            <span class="menu-header-text">Macros</span>


        <li class='menu-item@(currentPage == "/IMDSMacros/MultiForsBomToIMDS" ? " active" : "")'>
            <a asp-controller="IMDSMacros" asp-action="MultiForsBomToIMDS" class="menu-link">
                <i class="menu-icon icon-base bx bx-wrench"></i>
                <div class="text-truncate">FORS to IMDS BOMs</div>
            </a>
        </li>
        <li class='menu-item@(currentPage == "/IMDSMacros/IMDSBomToPorscheIMDS" ? " active" : "")'>
            <a asp-controller="IMDSMacros" asp-action="IMDSBomToPorscheIMDS" class="menu-link">
                <i class="menu-icon icon-base bx bx-wrench"></i>
                <div class="text-truncate">IMDS to Porsche BOMs</div>
            </a>
        </li>

        <!--/ Macros -->
   
     
       
        
    </ul>

</aside>
<!-- / Menu -->
