@using CSVWorker.Models.Entities
@model IMDSDatabaseRecord

@{
    ViewData["Title"] = "Delete";
}

<h1 class="fs-3">Confirm Delete</h1>


<div class="card">
    <h5 class="card-header">Confirm delete id @Html.DisplayFor(model => model.Id)</h5>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CreatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.createdBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.createdBy)
            </dd>
        </dl>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.LastUpdatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.LastUpdatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.LastUpdatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.LastUpdatedBy)
            </dd>
        </dl>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PartNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PartNumber)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ForsPN)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ForsPN)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.SIGIPPN)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SIGIPPN)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.VisualPN)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.VisualPN)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.WGK)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.WGK)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.NodeID)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.NodeID)
            </dd>
        </dl>
         <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="row mb-6">
                <p class="text-danger">Are you sure you want to delete this record?</p>
            </div>
            <div class="row mb-6">
                <div class="col-sm-10">
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    <a asp-action="Index" class="btn btn-secondary mx-2">Back</a>
                </div>
            </div>
         </form>
    </div>
</div>
