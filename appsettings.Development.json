{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "serilog/csvworker-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "CsvWorkerConfig": {
    // Default page size for paginated results
    "DefaultPageSize": 10,
    // Default number of log entries to return in the logs history endpoint
    // This can be adjusted based on the expected volume of logs and performance considerations
    "DefaultLogsHistoryCount": 30,
    "LogsPrefix": "csvworker"
  },
  "ConnectionStrings": {
    "MySqlConnection": "Server=localhost;Database=csvworkerdb;User=user;Password=dbpassword;Port=3306"
  },
  // in development I am using OpenLDAP server running in a Docker container, so the configuration is set accordingly
  // production setting is in appsettings.json and is set for Active Directory
  "LdapConfig": {
    // LDAP server address
    "Server": "localhost",

    // if UseSsl is true (LDAPS) use port 636 or else use port 389
    "Port": 389,

    // For LDAP authentication
    // It has to be capable of finding users and their assigned groups
    "AdminDn": "cn=admin,dc=leoni,dc=local",
    "AdminPassword": "AdminPassword123!",
    "BaseDn": "dc=leoni,dc=local",
    "UserOu": "ou=users",
    "GroupOu": "ou=groups",
    "DomainName": "leoni.local",

    // if UseSsl is true use port 636 or else use port 389
    "UseSsl": false,

    // Authentication type for LDAP connection (e.g.,  "negotiate", "basic", "NTLM", "digest", "external")
    "AuthType": "basic",

    // For Active Directory: (objectClass=group)
    // For OpenLDAP, the group class is usually "groupOfNames" or "groupOfUniqueNames", but it can vary based on the schema used
    "GroupClass": "groupOfNames",

    // Attribute name for user photo in AD (optional for user photo retreival)
    // For OpenLDAP it is JpegPhoto
    "PhotoAttribName": "JpegPhoto"
  }
}
